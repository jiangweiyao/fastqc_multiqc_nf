//params.in = "$baseDir/fastq/*.fastq.gz"
//params.out = "$HOME/test"

params {

    in_files = "$baseDir/fastq/*.fastq.gz"
    out_loc = "$HOME/test1"


}


process {
  withName:fastqc {
    container = 'quay.io/biocontainers/fastqc:0.11.9--0'
  }
  withName:multiqc {
    container = 'quay.io/biocontainers/multiqc:1.8--py_2'
  }
}
    

docker.enabled = true

report.enabled = true  

